# =============================================================================
# DOMORA — Environment variables (copy to .env.local and fill in)
# Validated at boot by src/lib/env.ts (zod).
# NEXT_PUBLIC_* are exposed to the browser — keep everything else server-only.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the app (used to build public tour URLs / iframes).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (region eu-central-1) ------------------------------------------
# Project URL + anon (public) key — Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic / Claude (step 6: agent IA) -----------------------------------
# Model id is read from env, never hardcoded.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Restyle 2D provider (step 7) --------------------------------------------
# Which provider the RestyleProvider abstraction uses: "fal" | "replicate"
RESTYLE_PROVIDER=fal
FAL_KEY=
REPLICATE_API_TOKEN=

# --- Resend (step 9: lead notification emails) -------------------------------
RESEND_API_KEY=
# Verified sender address used to email the agency.
RESEND_FROM_EMAIL=
# Optional fallback inbox for lead notifications.
LEADS_NOTIFICATION_EMAIL=
